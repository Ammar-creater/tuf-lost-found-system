# Create .gitignore with content
@"
# Environment variables (passwords - NEVER commit)
.env
.env.local
.env.production

# Dependencies
node_modules/
package-lock.json

# Database
*.sql
*.db

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
"@ | Out-File -FilePath .gitignore -Encoding utf8